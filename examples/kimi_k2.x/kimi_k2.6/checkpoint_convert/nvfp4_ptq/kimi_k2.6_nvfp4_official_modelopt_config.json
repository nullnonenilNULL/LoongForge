{
  "model_name": "nvidia/Kimi-K2.6-NVFP4",
  "recipe_from_hf_quant_config": {
    "producer": {
      "name": "modelopt",
      "version": "0.0.1.dev752+gbd4fc3a65.d20260504"
    },
    "quantization": {
      "quant_algo": "NVFP4",
      "kv_cache_quant_algo": "FP8",
      "group_size": 16,
      "exclude_modules": [
        "language_model.lm_head",
        "language_model.model.layers.0*",
        "language_model.model.layers.*.mlp.shared_experts*",
        "language_model.model.layers.*.self_attn*",
        "mm_projector*",
        "vision_tower*"
      ]
    }
  },
  "runtime_defaults": {
    "qformat": "nvfp4_mlp_only",
    "kv_cache_qformat": "fp8",
    "dataset": "cnn_dailymail,nemotron-post-training-dataset-v2",
    "calib_size": "512,512",
    "calib_seq": 512
  },
  "output_config": {
    "text_model_type": "deepseek_v3",
    "transformers_version": "4.57.3",
    "remove_torch_dtype": true
  }
}
